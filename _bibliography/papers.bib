@inproceedings{animireddy2026greenerai,
  title={Greener AI: Evaluating Carbon Emissions and Energy Efficiency in Large Language Models},
  author={Animireddy Gari, Harika and Ho, Duy},
  booktitle={Proceedings of the IEEE International Conference on Emerging Current Trends in Engineering and Technology (ICECET)},
  year={2026},
  selected={true},
  abbr={IEEE ICECET},
  abstract={This paper evaluates the carbon footprint and energy efficiency of large language models across multiple quantization precision modes (FP32, FP16, INT8, INT4) on Tesla T4 GPUs. Contrary to common assumptions, we find that INT8/INT4 quantization paradoxically increases CO2 emissions due to dequantization overhead, with FP16 emerging as the practical efficiency sweet spot across XSum, SQuAD, and ARC-Challenge benchmarks.}
}
